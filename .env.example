# ============================================================
#  Настройки LocalAI — скопируй в .env и измени под себя
#  cp .env.example .env
# ============================================================

# Порт веб-интерфейса (по умолчанию 3000)
WEBUI_PORT=3000

# Секретный ключ — СМЕНИ на случайный!
WEBUI_SECRET_KEY=localai-secret-change-me-please

# Название в интерфейсе
WEBUI_NAME=LocalAI

# Язык интерфейса (ru, en, de, fr, ...)
DEFAULT_LOCALE=ru

# Модель по умолчанию
# Лёгкие (~400MB): qwen2.5:0.5b, tinyllama
# Средние (~800MB): qwen2.5:1.5b, phi3:mini
# Мощные (4-8GB): llama3.2:3b, mistral:7b
DEFAULT_MODEL=qwen2.5:0.5b
